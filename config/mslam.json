{
    "imu": true,
    "lidar" : true,
    "camera": false,
    "log_level": "debug", // trace || debug || info || warning || error
    "map_type": "voxel", // kdtree || voxel
    "remote_scanner": "192.168.178.129:50051",

    "preprocessor": {
        "voxel_size": 0.1,
        "min_distance_to_center": 1.0,
        "downsample_filter": "voxel_hash", // voxel_hash || voxel_grid
        "points_per_second": 200000,
        "deskew": "off" // off || constant_velocity || imu
    },
    "map": {
        "resolution": 0.1,
        "max_points_per_voxel": 1
    },

    "slam": {
        "optimizer_iterations": 3,
        "reg_iterations": 3,
        "max_correspondence_distance": 0.2
    }
}